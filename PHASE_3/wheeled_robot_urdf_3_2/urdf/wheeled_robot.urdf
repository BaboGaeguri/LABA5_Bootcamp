<?xml version="1.0"?>
<!--
  ╔══════════════════════════════════════════════════════════╗
  ║         2륜 + 캐스터 바퀴 로봇 URDF 정의 파일           ║
  ║                                                          ║
  ║  Links:  base_link, left_wheel, right_wheel,             ║
  ║          caster_wheel                                    ║
  ║  Joints: left_wheel_joint (continuous),                  ║
  ║          right_wheel_joint (continuous),                 ║
  ║          caster_joint (fixed)                            ║
  ╚══════════════════════════════════════════════════════════╝
-->
<robot name="wheeled_robot">

  <!-- ════════════════════════════════════════
       MATERIALS (색상 정의)
       ════════════════════════════════════════ -->
  <material name="blue">
    <color rgba="0.2 0.4 0.8 1.0"/>
  </material>

  <material name="black">
    <color rgba="0.1 0.1 0.1 1.0"/>
  </material>

  <material name="gray">
    <color rgba="0.6 0.6 0.6 1.0"/>
  </material>


  <!-- ════════════════════════════════════════
       LINK 1: base_link (로봇 몸체)
       형태: 상자(box) — 가로 0.3m, 세로 0.2m, 높이 0.1m
       ════════════════════════════════════════ -->
  <link name="base_link">

    <!-- visual: RViz에서 보이는 시각적 형태 -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>   <!-- x=길이, y=폭, z=높이 -->
      </geometry>
      <material name="blue"/>
    </visual>

    <!-- collision: 물리 시뮬레이션의 충돌 판정 형태
         (visual과 동일하게 설정, 단순화 가능) -->
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </collision>

    <!-- inertial: 관성(질량/관성모멘트) — 시뮬레이션 필수 -->
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="0.00583" ixy="0" ixz="0"
                             iyy="0.01083" iyz="0"
                                           izz="0.01417"/>
    </inertial>

  </link>


  <!-- ════════════════════════════════════════
       LINK 2: left_wheel (왼쪽 바퀴)
       형태: 원기둥(cylinder) — 반지름 0.05m, 두께 0.03m
       ════════════════════════════════════════ -->
  <link name="left_wheel">

    <visual>
      <!-- 원기둥의 기본 축은 Z축 → Y축으로 회전시켜야 바퀴처럼 보임 -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>  <!-- 90도 = π/2 ≈ 1.5708 -->
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000063" ixy="0" ixz="0"
                              iyy="0.000063" iyz="0"
                                             izz="0.000125"/>
    </inertial>

  </link>


  <!-- ════════════════════════════════════════
       LINK 3: right_wheel (오른쪽 바퀴)
       형태: 원기둥 — 왼쪽과 동일한 크기
       ════════════════════════════════════════ -->
  <link name="right_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
      <material name="black"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.03"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.000063" ixy="0" ixz="0"
                              iyy="0.000063" iyz="0"
                                             izz="0.000125"/>
    </inertial>

  </link>


  <!-- ════════════════════════════════════════
       LINK 4: caster_wheel (보조 바퀴)
       형태: 구(sphere) — 반지름 0.025m
       ════════════════════════════════════════ -->
  <link name="caster_wheel">

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="gray"/>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0000125" ixy="0" ixz="0"
                               iyy="0.0000125" iyz="0"
                                               izz="0.0000125"/>
    </inertial>

  </link>


  <!-- ════════════════════════════════════════
       JOINT 1: left_wheel_joint
       type="continuous": 제한 없이 계속 회전 가능
       parent=base_link, child=left_wheel
       ════════════════════════════════════════ -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>

    <!-- origin: base_link 기준 left_wheel의 위치
         x=0: 앞뒤 중앙
         y=+0.115: 왼쪽으로 0.115m (몸체 폭 0.1 + 바퀴 두께 0.015)
         z=-0.05: 아래로 0.05m (몸체 바닥 높이) -->
    <origin xyz="0 0.115 -0.05" rpy="0 0 0"/>

    <!-- axis: 회전축 — Y축 기준으로 회전 (바퀴가 앞으로 구름) -->
    <axis xyz="0 1 0"/>

  </joint>


  <!-- ════════════════════════════════════════
       JOINT 2: right_wheel_joint
       type="continuous": 제한 없이 계속 회전 가능
       ════════════════════════════════════════ -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>

    <!-- y=-0.115: 오른쪽으로 (왼쪽과 반대) -->
    <origin xyz="0 -0.115 -0.05" rpy="0 0 0"/>

    <axis xyz="0 1 0"/>

  </joint>


  <!-- ════════════════════════════════════════
       JOINT 3: caster_joint
       type="fixed": 고정 (회전 없음)
       캐스터는 보통 passive이므로 fixed로 단순화
       ════════════════════════════════════════ -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>

    <!-- 앞쪽(-x 방향) 바닥에 위치
         x=-0.1: 앞쪽으로 0.1m
         z=-0.075: 아래로 (구 반지름 0.025 + 몸체 아래쪽 0.05) -->
    <origin xyz="-0.1 0 -0.075" rpy="0 0 0"/>

  </joint>


</robot>
