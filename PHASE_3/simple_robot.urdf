<robot name="two_wheel_robot">

  <!-- BASE -->
  <link name="base_link">

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="3.0"/>
      <inertia
        ixx="0.02"
        ixy="0.0"
        ixz="0.0"
        iyy="0.02"
        iyz="0.0"
        izz="0.03"/>
    </inertial> 

    <visual>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <box size="0.3 0.2 0.1"/>
      </geometry>
    </collision>
  </link>


  <!-- LEFT WHEEL -->
  <link name="left_wheel">

    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.3"/>
      <inertia
        ixx="0.0005"
        ixy="0.0"
        ixz="0.0"
        iyy="0.0005"
        iyz="0.0"
        izz="0.0005"/>
    </inertial> 

    <visual>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
  </link>


  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.3"/>
      <inertia
        ixx="0.0005"
        ixy="0.0"
        ixz="0.0"
        iyy="0.0005"
        iyz="0.0"
        izz="0.0005"/>
    </inertial> 

    <visual>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </visual>

    <collision>
      <origin rpy="1.5707 0 0"/>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
    </collision>
  </link>


  <!-- CASTER -->
  <link name="caster_wheel">
    
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia
        ixx="0.0002"
        ixy="0.0"
        ixz="0.0"
        iyy="0.0002"
        iyz="0.0"
        izz="0.0002"/>
    </inertial> 

    <visual>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </visual>

    <collision>
      <geometry>
        <sphere radius="0.03"/>
      </geometry>
    </collision>
  </link>


  <!-- LEFT JOINT -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.1 -0.05"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- RIGHT JOINT -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.1 -0.05"/>
    <axis xyz="0 1 0"/>
  </joint>


  <!-- CASTER JOINT -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="-0.1 0 -0.05"/>
  </joint>

  <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">

    <left_joint>left_wheel_joint</left_joint>
    <right_joint>right_wheel_joint</right_joint>

    <wheel_separation>0.2</wheel_separation>
    <wheel_radius>0.05</wheel_radius>

    <topic>/cmd_vel</topic>

  </plugin>

</robot>